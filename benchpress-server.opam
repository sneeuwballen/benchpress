# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
version: "0.1"
synopsis: "Server and web UI for benchpress"
maintainer: ["Simon Cruanes"]
authors: ["Simon Cruanes" "Guillaume Bury"]
license: "BSD-2-Clause"
homepage: "https://github.com/sneeuwballen/benchpress"
bug-reports: "https://github.com/sneeuwballen/benchpress/issues"
depends: [
  "ocaml" {>= "4.12"}
  "dune" {>= "3.2"}
  "base-unix"
  "containers" {>= "3.0" & < "4.0"}
  "csv"
  "benchpress" {= version}
  "cmdliner" {>= "1.1.0"}
  "logs"
  "uuidm"
  "base64"
  "gnuplot" {>= "0.6" & < "0.8"}
  "sqlite3"
  "sqlite3_utils" {>= "0.4" & < "0.5"}
  "tiny_httpd" {>= "0.17" & < "1.0"}
  "printbox" {>= "0.12"}
  "printbox-text" {>= "0.12"}
  "jemalloc" {>= "0.2" & < "0.3"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/sneeuwballen/benchpress.git"
